{
  "permissions": {
    "allow": [
      "Bash(gh pr merge:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR:-.}\"/scripts/comment-pass.sh hook",
            "timeout": 15,
            "statusMessage": "Checking Java comment-pass attestation (D60)"
          }
        ]
      }
    ]
  }
}
