{
  "name": "thinlet-modernized (JDK 21)",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      // The CI matrix builds the same Dockerfile per JDK target, switching only
      // this arg (8 / 11 / 17 / 21 / 25). The default dev image is the LTS used
      // to run Maven itself.
      "JDK_VERSION": "21"
    }
  },
  // desktop-lite: a lightweight Fluxbox desktop reachable via noVNC in a browser
  // (forwarded port 6080), so the GUI demos can actually be *seen* while
  // developing. It runs on its own display (:1); the trace harness keeps a
  // separate, controlled headless Xvfb on :99 (see containerEnv + DECISIONS.md
  // D22). Dev-only: the CI build overrides the entrypoint, so the desktop never
  // starts in CI. Default noVNC password is "vscode".
  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {}
  },
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": { "label": "Desktop (noVNC)", "onAutoForward": "silent" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "redhat.vscode-xml",
        "EditorConfig.EditorConfig"
      ],
      "settings": {
        "java.configuration.runtimes": [
          { "name": "JavaSE-21", "path": "/usr/local/sdkman/candidates/java/current" }
        ]
      }
    }
  },
  // Interactive default display is the viewable desktop-lite/noVNC desktop (:1),
  // so demos launched from the editor or terminal appear in the browser desktop.
  // The golden-trace harness instead uses a dedicated, controlled headless Xvfb
  // on :99 (set explicitly for those runs) so window-manager chrome never
  // pollutes pixel metrics — see DECISIONS.md D7/D22. Pinned fonts + fontconfig
  // are baked into the image so local and CI font metrics share one glyph source.
  "containerEnv": {
    "DISPLAY": ":1"
  },
  // Persist the Maven local repo across rebuilds. The named volume mounts
  // root-owned, but the build runs as `vscode`; chown it on create so `mvn` /
  // `./mvnw` can write ~/.m2 (runs on every rebuild, so it also repairs an
  // already-root-owned volume). CI does not rely on this — it points
  // MAVEN_USER_HOME at the writable workspace .m2 instead (see DECISIONS.md D19).
  "mounts": [
    "source=thinlet-m2,target=/home/vscode/.m2,type=volume"
  ],
  "postCreateCommand": "sudo chown -R vscode:vscode /home/vscode/.m2 && (git rev-parse --git-dir >/dev/null 2>&1 && pre-commit install || true)",
  "remoteUser": "vscode"
}
