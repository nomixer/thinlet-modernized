# EditorConfig — https://editorconfig.org
# Whitespace hygiene for the thinlet-modernized repo.
#
# NOTE: *.dtd is intentionally NOT covered here. thinlet.dtd is preserved
# byte-verbatim from the 2005 archive; no trim / EOL normalization is applied
# to it (see DECISIONS.md and .gitattributes, which marks *.dtd binary).

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{java,xml}]
indent_style = space
indent_size = 4

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# Maven wrapper properties etc.
[*.properties]
indent_size = 4

# thinlet.dtd stays byte-verbatim — no EditorConfig rules applied.
[*.dtd]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset
