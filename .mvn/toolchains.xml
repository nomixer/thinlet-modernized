<?xml version="1.0" encoding="UTF-8"?>
<!--
  JDK toolchains for the cross-JDK test matrix (DECISIONS.md D14/D25/D31).
  Passed via `-t .mvn/toolchains.xml` with the `crossjdk` profile so
  maven-toolchains-plugin selects the row's JDK (`-Djdk.target=N`) and surefire
  forks the golden-trace tests on it, while Maven itself keeps running on the base
  JDK (21) and the compiler emits the one portable release-8 jar on the JVM-21
  javac. Only the *test* runtime varies per row. Runtimes 8/11/17 are listed here;
  the JDK 21 runtime is covered by the base-JVM `build` job (no toolchain needed).
  The jdkHome paths are provided by the dev-container image (.devcontainer/Dockerfile).
-->
<toolchains>
  <toolchain>
    <type>jdk</type>
    <provides>
      <version>8</version>
    </provides>
    <configuration>
      <jdkHome>/opt/jdk8</jdkHome>
    </configuration>
  </toolchain>
  <toolchain>
    <type>jdk</type>
    <provides>
      <version>11</version>
    </provides>
    <configuration>
      <jdkHome>/opt/jdk11</jdkHome>
    </configuration>
  </toolchain>
  <toolchain>
    <type>jdk</type>
    <provides>
      <version>17</version>
    </provides>
    <configuration>
      <jdkHome>/opt/jdk17</jdkHome>
    </configuration>
  </toolchain>
</toolchains>
